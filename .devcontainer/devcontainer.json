{
  "name": "Tailscale ExitNode",
  "capAdd": [
    "NET_ADMIN",
    "NET_RAW"
  ],
  "features": {
    "ghcr.io/tailscale/codespace/tailscale": {
      "version": "latest"
    }
  },
  "postStartCommand": "tailscale up --advertise-exit-node --authkey=${TAILSCALE_AUTHKEY} --reset",
  "remoteUser": "codespace"
}
